  },
  "name": "Send marketing email from New blog post and send to Twitter",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Send marketing email from New blog post and send to Twitter",
  "category": "AI",
  "tags": [
    "n8n 2000 workflows",
    "slack",
    "webhook",
    "send",
    "marketing",
    "email",
    "blog",
    "post"
  ],
  "task_keywords": [
    "send marketing email from new blog post and send to twitter",
    "slack",
    "send slack",
    "webhook",
    "send marketing",
    "marketing email",
    "email blog",
    "blog post",
    "post send",
    "send twitter",
    "twitter n8n",
    "n8n workflow"
  ],
  "required_services": [
    "slack"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Send marketing email from New blog post and send to Twitter",
    "nodes": [
      {
        "id": "trigger-new-blog-post",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          63000
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "send-marketing-email-from-new-blog-post-and-send-to-twitter",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-new-blog-post",
        "name": "Fetch data from New blog post",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          63000
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/new-blog-post",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-twitter",
        "name": "Send to Twitter",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          63000
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/twitter",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-63000",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          63000
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from New blog post",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from New blog post": {
        "main": [
          {
            "node": "Send to Twitter",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Twitter": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
}
