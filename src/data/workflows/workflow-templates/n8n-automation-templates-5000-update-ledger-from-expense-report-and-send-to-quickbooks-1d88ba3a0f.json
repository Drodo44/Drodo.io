  "workflow": {
    "name": "Update ledger from Expense report and send to QuickBooks",
    "nodes": [
      {
        "id": "trigger-expense-report",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          129300
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "update-ledger-from-expense-report-and-send-to-quickbooks",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-expense-report",
        "name": "Fetch data from Expense report",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          129300
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/expense-report",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-quickbooks",
        "name": "Send to QuickBooks",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          129300
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/quickbooks",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-129300",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          129300
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Expense report",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Expense report": {
        "main": [
          {
            "node": "Send to QuickBooks",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to QuickBooks": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
