  "workflow": {
    "name": "Escalate priority from Call transcript and send to Notion",
    "nodes": [
      {
        "id": "trigger-call-transcript",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          97300
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "escalate-priority-from-call-transcript-and-send-to-notion",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-call-transcript",
        "name": "Fetch data from Call transcript",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          97300
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/call-transcript",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-notion",
        "name": "Send to Notion",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          97300
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/notion",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-97300",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          97300
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Call transcript",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Call transcript": {
        "main": [
