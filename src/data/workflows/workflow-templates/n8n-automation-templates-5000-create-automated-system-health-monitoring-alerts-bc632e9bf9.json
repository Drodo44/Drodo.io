  },
  "name": "create-automated-system-health-monitoring-alerts",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: create-automated-system-health-monitoring-alerts",
  "category": "Communication",
  "tags": [
    "n8n advance",
