  "workflow": {
    "name": "Approve expense from QuickBooks transaction and send to Accounting DB",
    "nodes": [
      {
        "id": "trigger-quickbooks-transaction",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          133700
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "approve-expense-from-quickbooks-transaction-and-send-to-accounting-db",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-quickbooks-transaction",
        "name": "Fetch data from QuickBooks transaction",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          133700
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/quickbooks-transaction",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-accounting-db",
        "name": "Send to Accounting DB",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          133700
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/accounting-db",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-133700",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          133700
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from QuickBooks transaction",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from QuickBooks transaction": {
