  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Generate offer letter from Job portal and send to Slack",
    "nodes": [
      {
        "id": "trigger-job-portal",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          113400
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "generate-offer-letter-from-job-portal-and-send-to-slack",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-job-portal",
        "name": "Fetch data from Job portal",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          113400
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/job-portal",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-generate-offer-letter",
        "name": "AI: Generate Offer Letter",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          113400
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: generate offer letter"
        }
      },
      {
        "id": "send-slack",
        "name": "Send to Slack",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          113400
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/slack",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-113400",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          113400
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Job portal",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Job portal": {
        "main": [
          {
            "node": "AI: Generate Offer Letter",
            "type": "main",
            "index": 0
          }
        ]
      },
      "AI: Generate Offer Letter": {
        "main": [
          [
            {
              "node": "AI: Generate Offer Letter",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Send to Slack": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
