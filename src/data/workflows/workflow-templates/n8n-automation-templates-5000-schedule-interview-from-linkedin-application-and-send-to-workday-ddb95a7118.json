  "workflow": {
    "name": "Schedule interview from LinkedIn application and send to Workday",
    "nodes": [
      {
        "id": "trigger-linkedin-application",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          115500
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "schedule-interview-from-linkedin-application-and-send-to-workday",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-linkedin-application",
        "name": "Fetch data from LinkedIn application",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          115500
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/linkedin-application",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-workday",
        "name": "Send to Workday",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          115500
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/workday",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-115500",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          115500
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from LinkedIn application",
              "type": "main",
              "index": 0
            }
          ]
        ]
