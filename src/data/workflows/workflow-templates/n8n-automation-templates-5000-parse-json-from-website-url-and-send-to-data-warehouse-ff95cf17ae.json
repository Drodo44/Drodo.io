  },
  "name": "Parse json from Website URL and send to Data warehouse",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Parse json from Website URL and send to Data warehouse",
  "category": "Data",
  "tags": [
    "n8n 2000 workflows",
    "slack",
