  },
  "name": "Create social media posts from New blog post and send to HubSpot",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Create social media posts from New blog post and send to HubSpot",
  "category": "Marketing",
  "tags": [
    "n8n 2000 workflows",
    "slack",
    "webhook",
    "create",
    "social",
    "media",
    "posts",
    "blog",
    "post"
  ],
  "task_keywords": [
    "create social media posts from new blog post and send to hubspot",
    "slack",
    "send slack",
    "create slack",
    "webhook",
    "create social",
    "social media",
    "media posts",
    "posts blog",
    "blog post",
    "post send",
    "send hubspot"
  ],
  "required_services": [
    "slack"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Create social media posts from New blog post and send to HubSpot",
    "nodes": [
      {
        "id": "trigger-new-blog-post",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          60400
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "create-social-media-posts-from-new-blog-post-and-send-to-hubspot",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-new-blog-post",
        "name": "Fetch data from New blog post",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          60400
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/new-blog-post",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-hubspot",
        "name": "Send to HubSpot",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          60400
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/hubspot",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-60400",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          60400
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from New blog post",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from New blog post": {
        "main": [
          {
            "node": "Send to HubSpot",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to HubSpot": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
}
