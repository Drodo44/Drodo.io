  },
  "name": "Score lead with ai from Google Ads and send to Pipedrive",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Score lead with ai from Google Ads and send to Pipedrive",
  "category": "AI",
  "tags": [
    "n8n 2000 workflows",
    "open AIApi",
    "slack",
    "webhook",
    "score",
    "lead",
    "google",
    "ads",
