  ],
  "task_keywords": [
    "score lead with ai from google ads and send to pipedrive",
    "open aiapi",
    "send open aiapi",
    "slack",
    "send slack",
    "webhook",
    "score lead",
    "lead google",
    "google ads",
    "ads send",
    "send pipedrive",
    "pipedrive n8n"
  ],
  "required_services": [
    "open AIApi",
    "slack"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Score lead with ai from Google Ads and send to Pipedrive",
    "nodes": [
      {
        "id": "trigger-google-ads",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          37200
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "score-lead-with-ai-from-google-ads-and-send-to-pipedrive",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-google-ads",
        "name": "Fetch data from Google Ads",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          37200
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/google-ads",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-score-lead-with-ai",
        "name": "AI: Score Lead With Ai",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          37200
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: score lead with AI"
        }
      },
      {
        "id": "send-pipedrive",
        "name": "Send to Pipedrive",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          37200
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/pipedrive",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-37200",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          37200
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Google Ads",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Google Ads": {
        "main": [
          {
            "node": "AI: Score Lead With Ai",
            "type": "main",
            "index": 0
          }
        ]
      },
      "AI: Score Lead With Ai": {
        "main": [
          [
            {
              "node": "AI: Score Lead With Ai",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Send to Pipedrive": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
}
