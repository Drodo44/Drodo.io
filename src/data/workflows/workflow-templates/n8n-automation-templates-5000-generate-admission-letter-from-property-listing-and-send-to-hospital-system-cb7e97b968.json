  "workflow": {
    "name": "Generate admission letter from Property listing and send to Hospital system",
    "nodes": [
      {
        "id": "trigger-property-listing",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          188200
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "generate-admission-letter-from-property-listing-and-send-to-hospital-system",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-property-listing",
        "name": "Fetch data from Property listing",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          188200
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/property-listing",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-generate-admission-letter",
        "name": "AI: Generate Admission Letter",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          188200
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: generate admission letter"
        }
      },
      {
        "id": "send-hospital-system",
        "name": "Send to Hospital system",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          188200
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/hospital-system",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-188200",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          188200
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Property listing",
