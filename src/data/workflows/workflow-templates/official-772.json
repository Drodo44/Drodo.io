{
  "id": "official-772",
  "source": {
    "type": "official",
    "url": "https://n8n.io/workflows/772",
    "template_id": 772
  },
  "name": "Send bulk messages to chats in Telegram",
  "description": "The Telegram API has a limitation to send only 30 messages per second.",
  "category": "Marketing",
  "tags": [
    "Social Media",
    "manual",
    "Telegram",
    "Google Sheets",
    "Loop Over Items (Split in Batches)",
    "Manual Trigger",
    "send",
    "bulk",
    "messages",
    "chats",
    "telegram"
  ],
  "task_keywords": [
    "send bulk messages to chats in telegram",
    "manual",
    "send manual",
    "telegram",
    "send telegram",
    "google sheets",
    "send google sheets",
    "loop over items (split in batches)",
    "send loop over items (split in batches)",
    "manual trigger",
    "send bulk",
    "bulk messages"
  ],
  "required_services": [
    "manual",
    "Telegram",
    "Google Sheets",
    "Loop Over Items (Split in Batches)"
  ],
  "triggers": [
    "Manual Trigger"
  ],
  "complexity": "simple",
  "workflow": {
    "nodes": [
      {
        "name": "On clicking 'execute'",
        "type": "n8n-nodes-base.manualTrigger",
        "position": [
          -60,
          400
        ],
        "parameters": {},
        "typeVersion": 1
      },
      {
        "name": "Telegram",
        "type": "n8n-nodes-base.telegram",
        "position": [
          500,
          400
        ],
        "parameters": {
          "text": "Hello",
          "chatId": "={{$node[\"SplitInBatches\"].json[\"Chat ID\"]}}",
          "additionalFields": {}
        },
        "credentials": {
          "telegramApi": {
            "id": "credential-id",
            "name": "telegramApi Credential"
          }
        },
        "typeVersion": 1
      },
      {
        "name": "Google Sheets",
        "type": "n8n-nodes-base.googleSheets",
        "position": [
          120,
          400
        ],
        "parameters": {
          "range": "A:A",
          "options": {},
          "authentication": "oAuth2"
        },
        "credentials": {
          "googleSheetsOAuth2Api": {
            "id": "credential-id",
            "name": "googleSheetsOAuth2Api Credential"
          }
        },
        "typeVersion": 1
      },
      {
        "name": "SplitInBatches",
        "type": "n8n-nodes-base.splitInBatches",
        "position": [
          320,
          400
        ],
        "parameters": {
          "options": {},
          "batchSize": 30
        },
        "typeVersion": 1
      },
      {
        "name": "Wait1",
        "type": "n8n-nodes-base.wait",
        "position": [
          660,
          180
        ],
        "webhookId": "22fca54c-eac4-44bc-adf7-68b33818695c",
        "parameters": {
          "unit": "seconds",
          "amount": 30
        },
        "typeVersion": 1
      }
    ],
    "connections": {
      "Wait1": {
        "main": [
          [
            {
              "node": "SplitInBatches",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Telegram": {
        "main": [
          [
            {
              "node": "Wait1",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Google Sheets": {
        "main": [
          [
            {
              "node": "SplitInBatches",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "SplitInBatches": {
        "main": [
          [
            {
              "node": "Telegram",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "On clicking 'execute'": {
        "main": [
          [
            {
              "node": "Google Sheets",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    }
  }
}
