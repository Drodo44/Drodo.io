  },
  "name": "Send rejection email from Resume email and send to Google Sheets",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Send rejection email from Resume email and send to Google Sheets",
  "category": "AI",
  "tags": [
    "n8n 2000 workflows",
    "slack",
    "webhook",
    "send",
    "rejection",
    "email",
    "resume"
  ],
  "task_keywords": [
    "send rejection email from resume email and send to google sheets",
    "slack",
    "send slack",
    "webhook",
    "send rejection",
    "rejection email",
    "email resume",
    "resume email",
    "email send",
    "send google",
    "google sheets",
    "sheets n8n"
  ],
  "required_services": [
    "slack"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Send rejection email from Resume email and send to Google Sheets",
    "nodes": [
      {
        "id": "trigger-resume-email",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          101200
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "send-rejection-email-from-resume-email-and-send-to-google-sheets",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-resume-email",
        "name": "Fetch data from Resume email",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          101200
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/resume-email",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-google-sheets",
        "name": "Send to Google Sheets",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          101200
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/google-sheets",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-101200",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          101200
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Resume email",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Resume email": {
        "main": [
          {
            "node": "Send to Google Sheets",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Google Sheets": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
}
