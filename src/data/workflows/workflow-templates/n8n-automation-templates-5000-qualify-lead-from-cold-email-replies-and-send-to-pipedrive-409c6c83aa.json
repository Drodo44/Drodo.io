  "workflow": {
    "name": "Qualify lead from Cold email replies and send to Pipedrive",
    "nodes": [
      {
        "id": "trigger-cold-email-replies",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          53300
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "qualify-lead-from-cold-email-replies-and-send-to-pipedrive",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-cold-email-replies",
        "name": "Fetch data from Cold email replies",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          53300
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/cold-email-replies",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-pipedrive",
        "name": "Send to Pipedrive",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          53300
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/pipedrive",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-53300",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          53300
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Cold email replies",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Cold email replies": {
        "main": [
          {
            "node": "Send to Pipedrive",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Pipedrive": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
