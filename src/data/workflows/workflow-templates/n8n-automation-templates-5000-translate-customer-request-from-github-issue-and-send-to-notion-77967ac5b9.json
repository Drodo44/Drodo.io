  },
  "name": "Translate customer request from GitHub issue and send to Notion",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Translate customer request from GitHub issue and send to Notion",
  "category": "AI",
  "tags": [
    "n8n 2000 workflows",
    "open AIApi",
    "slack",
    "webhook",
    "translate",
    "customer",
    "request",
