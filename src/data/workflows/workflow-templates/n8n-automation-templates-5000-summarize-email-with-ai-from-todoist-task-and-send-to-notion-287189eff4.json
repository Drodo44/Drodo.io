  "complexity": "simple",
  "workflow": {
    "name": "Summarize email with ai from Todoist task and send to Notion",
    "nodes": [
      {
        "id": "trigger-todoist-task",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          180800
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "summarize-email-with-ai-from-todoist-task-and-send-to-notion",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-todoist-task",
        "name": "Fetch data from Todoist task",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          180800
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/todoist-task",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-summarize-email-with-ai",
        "name": "AI: Summarize Email With Ai",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          180800
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: summarize email with AI"
        }
      },
      {
        "id": "send-notion",
        "name": "Send to Notion",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          180800
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/notion",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-180800",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          180800
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Todoist task",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Todoist task": {
        "main": [
          {
            "node": "AI: Summarize Email With Ai",
            "type": "main",
            "index": 0
          }
        ]
      },
      "AI: Summarize Email With Ai": {
        "main": [
          [
            {
              "node": "AI: Summarize Email With Ai",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Send to Notion": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
