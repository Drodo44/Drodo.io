      },
      "AI: Classify Resume With Ai": {
        "main": [
          [
            {
              "node": "AI: Classify Resume With Ai",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Send to Slack": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
