  ],
  "complexity": "simple",
  "workflow": {
    "name": "Classify resume with ai from Resume email and send to Slack",
    "nodes": [
      {
        "id": "trigger-resume-email",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          100200
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "classify-resume-with-ai-from-resume-email-and-send-to-slack",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-resume-email",
        "name": "Fetch data from Resume email",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          100200
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/resume-email",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-classify-resume-with-ai",
        "name": "AI: Classify Resume With Ai",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          100200
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: classify resume with AI"
        }
      },
      {
        "id": "send-slack",
        "name": "Send to Slack",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          100200
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/slack",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-100200",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          100200
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Resume email",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Resume email": {
