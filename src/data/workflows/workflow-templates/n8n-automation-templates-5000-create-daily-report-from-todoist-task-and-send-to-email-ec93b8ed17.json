          }
        ]
      },
      "AI: Create Daily Report": {
        "main": [
          [
            {
              "node": "AI: Create Daily Report",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Send to Email": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
