  },
  "name": "Store in sheet from External API and send to Google Sheets",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Store in sheet from External API and send to Google Sheets",
  "category": "Communication",
  "tags": [
    "n8n 2000 workflows",
    "slack",
