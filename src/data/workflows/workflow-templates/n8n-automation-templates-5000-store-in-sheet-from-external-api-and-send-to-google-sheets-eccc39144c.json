    "sheet external",
    "external send",
    "send google",
    "google sheets",
    "sheets n8n",
    "n8n workflow",
    "workflow template"
  ],
  "required_services": [
    "slack"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Store in sheet from External API and send to Google Sheets",
    "nodes": [
      {
        "id": "trigger-external-api",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          198100
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "store-in-sheet-from-external-api-and-send-to-google-sheets",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-external-api",
        "name": "Fetch data from External API",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          198100
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/external-api",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-google-sheets",
        "name": "Send to Google Sheets",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          198100
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/google-sheets",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-198100",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          198100
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from External API",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from External API": {
        "main": [
          {
            "node": "Send to Google Sheets",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Google Sheets": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
}
