  },
  "name": "Generate product description from Microsoft Teams and send to Salesforce",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Generate product description from Microsoft Teams and send to Salesforce",
  "category": "AI",
  "tags": [
    "n8n 2000 workflows",
    "open AIApi",
    "slack",
    "webhook",
    "generate",
    "product",
    "description",
    "microsoft",
