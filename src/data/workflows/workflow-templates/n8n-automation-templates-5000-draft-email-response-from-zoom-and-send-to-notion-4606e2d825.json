  },
  "name": "Draft email response from Zoom and send to Notion",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Draft email response from Zoom and send to Notion",
  "category": "AI",
  "tags": [
    "n8n 2000 workflows",
    "open AIApi",
    "slack",
    "webhook",
    "draft",
    "email",
    "response",
    "zoom",
    "send",
    "notion"
  ],
  "task_keywords": [
    "draft email response from zoom and send to notion",
    "open aiapi",
    "send open aiapi",
    "slack",
    "send slack",
    "webhook",
    "draft email",
    "email response",
    "response zoom",
    "zoom send",
    "send notion",
    "notion n8n"
  ],
  "required_services": [
    "open AIApi",
    "slack"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Draft email response from Zoom and send to Notion",
    "nodes": [
      {
        "id": "trigger-zoom",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          1800
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "draft-email-response-from-zoom-and-send-to-notion",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-zoom",
        "name": "Fetch data from Zoom",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          1800
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/zoom",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-draft-email-response",
        "name": "AI: Draft Email Response",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          1800
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: draft email response"
        }
      },
      {
        "id": "send-notion",
        "name": "Send to Notion",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          1800
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/notion",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-1800",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          1800
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Zoom",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Zoom": {
        "main": [
          {
            "node": "AI: Draft Email Response",
            "type": "main",
            "index": 0
          }
        ]
      },
      "AI: Draft Email Response": {
        "main": [
          [
            {
              "node": "AI: Draft Email Response",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Send to Notion": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
}
