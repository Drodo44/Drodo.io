  },
  "name": "Reconcile payment from Stripe payment and send to Google Drive",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Reconcile payment from Stripe payment and send to Google Drive",
  "category": "Communication",
  "tags": [
    "n8n 2000 workflows",
    "slack",
    "webhook",
    "reconcile",
    "payment",
    "stripe",
    "send",
    "google"
  ],
  "task_keywords": [
    "reconcile payment from stripe payment and send to google drive",
    "slack",
    "send slack",
    "webhook",
    "reconcile payment",
    "payment stripe",
    "stripe payment",
    "payment send",
    "send google",
    "google drive",
    "drive n8n",
    "n8n workflow"
  ],
  "required_services": [
    "slack"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Reconcile payment from Stripe payment and send to Google Drive",
    "nodes": [
      {
        "id": "trigger-stripe-payment",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          125000
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "reconcile-payment-from-stripe-payment-and-send-to-google-drive",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-stripe-payment",
        "name": "Fetch data from Stripe payment",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          125000
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/stripe-payment",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-google-drive",
        "name": "Send to Google Drive",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          125000
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/google-drive",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-125000",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          125000
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Stripe payment",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Stripe payment": {
        "main": [
          {
            "node": "Send to Google Drive",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Google Drive": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
}
