        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          106100
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "generate-offer-letter-from-application-form-and-send-to-airtable",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-application-form",
        "name": "Fetch data from Application form",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          106100
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/application-form",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-generate-offer-letter",
        "name": "AI: Generate Offer Letter",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          106100
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: generate offer letter"
        }
      },
      {
        "id": "send-airtable",
        "name": "Send to Airtable",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          106100
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/airtable",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-106100",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          106100
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
