  "name": "Create response draft from Intercom chat and send to CRM",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Create response draft from Intercom chat and send to CRM",
  "category": "AI",
  "tags": [
    "n8n 2000 workflows",
