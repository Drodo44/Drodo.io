    "url": "https://github.com/ritik-prog/n8n-automation-templates-5000/blob/main/n8n_2000_workflows/classify-action-items-google-meet-crm.json"
  },
  "name": "Classify action items from Google Meet and send to CRM",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Classify action items from Google Meet and send to CRM",
  "category": "AI",
  "tags": [
    "n8n 2000 workflows",
    "open AIApi",
    "slack",
    "webhook",
    "classify",
    "action",
    "items",
    "google",
    "meet",
    "send"
  ],
  "task_keywords": [
    "classify action items from google meet and send to crm",
    "open aiapi",
    "send open aiapi",
    "slack",
    "send slack",
    "webhook",
    "classify action",
    "action items",
    "items google",
    "google meet",
    "meet send",
    "send crm"
  ],
  "required_services": [
    "open AIApi",
    "slack"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Classify action items from Google Meet and send to CRM",
    "nodes": [
      {
        "id": "trigger-google-meet",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          14400
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "classify-action-items-from-google-meet-and-send-to-crm",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-google-meet",
        "name": "Fetch data from Google Meet",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          14400
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/google-meet",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-classify-action-items",
        "name": "AI: Classify Action Items",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          14400
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: classify action items"
        }
      },
      {
        "id": "send-crm",
        "name": "Send to CRM",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          14400
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/crm",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-14400",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          14400
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Google Meet",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Google Meet": {
        "main": [
          {
            "node": "AI: Classify Action Items",
            "type": "main",
            "index": 0
          }
        ]
      },
      "AI: Classify Action Items": {
        "main": [
          [
            {
              "node": "AI: Classify Action Items",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Send to CRM": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
}
