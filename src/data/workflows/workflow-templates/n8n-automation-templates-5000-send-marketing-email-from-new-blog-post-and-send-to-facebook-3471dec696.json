  "complexity": "simple",
  "workflow": {
    "name": "Send marketing email from New blog post and send to Facebook",
    "nodes": [
      {
        "id": "trigger-new-blog-post",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          63100
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "send-marketing-email-from-new-blog-post-and-send-to-facebook",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-new-blog-post",
        "name": "Fetch data from New blog post",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          63100
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/new-blog-post",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-facebook",
        "name": "Send to Facebook",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          63100
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/facebook",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-63100",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          63100
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from New blog post",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from New blog post": {
        "main": [
          {
            "node": "Send to Facebook",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Facebook": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
