  },
  "name": "Run test suite from GitHub issue and send to Notion",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Run test suite from GitHub issue and send to Notion",
  "category": "Communication",
  "tags": [
    "n8n 2000 workflows",
    "slack",
    "webhook",
    "run",
    "test",
    "suite",
    "github",
    "issue",
    "send"
  ],
  "task_keywords": [
    "run test suite from github issue and send to notion",
    "slack",
    "send slack",
    "webhook",
    "run test",
    "test suite",
    "suite github",
    "github issue",
    "issue send",
    "send notion",
    "notion n8n",
    "n8n workflow"
  ],
  "required_services": [
    "slack"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Run test suite from GitHub issue and send to Notion",
    "nodes": [
      {
        "id": "trigger-github-issue",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          138300
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "run-test-suite-from-github-issue-and-send-to-notion",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-github-issue",
        "name": "Fetch data from GitHub issue",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          138300
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/github-issue",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-notion",
        "name": "Send to Notion",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          138300
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/notion",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-138300",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          138300
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from GitHub issue",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from GitHub issue": {
        "main": [
          {
            "node": "Send to Notion",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Notion": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
}
