      },
      {
        "id": "3a739102-4c56-4125-949c-a54775073a64",
        "name": "Respond with Image URL",
        "type": "n8n-nodes-base.respondToWebhook",
        "position": [
          1500,
          640
        ],
        "parameters": {
          "options": {},
          "respondWith": "allIncomingItems"
        },
        "typeVersion": 1.2
      }
