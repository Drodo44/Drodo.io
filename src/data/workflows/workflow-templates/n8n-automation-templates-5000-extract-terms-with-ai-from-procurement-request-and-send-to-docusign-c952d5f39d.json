          163900
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: extract terms with AI"
        }
      },
      {
        "id": "send-docusign",
        "name": "Send to DocuSign",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          163900
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/docusign",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-163900",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          163900
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
