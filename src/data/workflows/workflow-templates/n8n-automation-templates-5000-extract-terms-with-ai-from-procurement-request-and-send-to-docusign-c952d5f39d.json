        "parameters": {
          "httpMethod": "POST",
          "path": "extract-terms-with-ai-from-procurement-request-and-send-to-docusign",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-procurement-request",
        "name": "Fetch data from Procurement request",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          163900
        ],
        "parameters": {
