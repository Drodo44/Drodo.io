    "update slack",
    "webhook",
    "update lead",
    "lead status",
    "status facebook",
    "facebook ads",
    "ads send",
    "send hubspot",
    "hubspot n8n"
  ],
  "required_services": [
    "slack"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Update lead status from Facebook Ads and send to HubSpot",
    "nodes": [
      {
        "id": "trigger-facebook-ads",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          35000
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "update-lead-status-from-facebook-ads-and-send-to-hubspot",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-facebook-ads",
        "name": "Fetch data from Facebook Ads",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          35000
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/facebook-ads",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-hubspot",
        "name": "Send to HubSpot",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          35000
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/hubspot",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-35000",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          35000
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Facebook Ads",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Facebook Ads": {
        "main": [
          {
            "node": "Send to HubSpot",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to HubSpot": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
}
