  },
  "name": "Update lead status from Facebook Ads and send to HubSpot",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Update lead status from Facebook Ads and send to HubSpot",
  "category": "Communication",
  "tags": [
    "n8n 2000 workflows",
    "slack",
    "webhook",
    "update",
    "lead",
    "status",
    "facebook",
    "ads",
