  "name": "Translate customer request from Intercom chat and send to Email",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Translate customer request from Intercom chat and send to Email",
  "category": "AI",
  "tags": [
    "n8n 2000 workflows",
    "open AIApi",
    "slack",
    "webhook",
    "translate",
    "customer",
    "request",
    "intercom",
