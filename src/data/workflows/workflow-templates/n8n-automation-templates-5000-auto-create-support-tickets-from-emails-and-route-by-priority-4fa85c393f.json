  },
  "name": "auto-create-support-tickets-from-emails-and-route-by-priority",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: auto-create-support-tickets-from-emails-and-route-by-priority",
  "category": "AI",
  "tags": [
    "n8n advance",
    "email Read Imap",
    "function",
    "openai",
    "slack",
    "auto",
    "create",
    "support",
    "tickets",
