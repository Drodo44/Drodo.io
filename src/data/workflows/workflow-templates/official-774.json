    "via",
    "message"
  ],
  "task_keywords": [
    "send daily weather updates via a message using the gotify node",
    "cron",
    "send cron",
    "update cron",
    "openweathermap",
    "send openweathermap",
    "update openweathermap",
    "gotify",
    "send gotify",
    "update gotify",
