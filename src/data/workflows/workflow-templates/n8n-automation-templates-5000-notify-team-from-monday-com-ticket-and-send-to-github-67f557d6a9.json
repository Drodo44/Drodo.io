    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Notify team from Monday.com ticket and send to GitHub",
    "nodes": [
      {
        "id": "trigger-monday-com-ticket",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          159200
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "notify-team-from-monday-com-ticket-and-send-to-github",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-monday-com-ticket",
        "name": "Fetch data from Monday.com ticket",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          159200
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/monday-com-ticket",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-github",
        "name": "Send to GitHub",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          159200
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/github",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-159200",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          159200
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Monday.com ticket",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Monday.com ticket": {
        "main": [
          {
            "node": "Send to GitHub",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to GitHub": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
