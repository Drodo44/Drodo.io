  },
  "name": "Generate invoice pdf from Xero invoice and send to Email",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Generate invoice pdf from Xero invoice and send to Email",
  "category": "AI",
  "tags": [
    "n8n 2000 workflows",
    "slack",
    "webhook",
    "generate",
    "invoice",
    "pdf",
    "xero",
    "send"
  ],
  "task_keywords": [
    "generate invoice pdf from xero invoice and send to email",
    "slack",
    "send slack",
