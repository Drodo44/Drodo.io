    "OpenWeatherMap",
    "Spontit",
    "Cron Trigger",
    "send",
    "daily",
    "weather",
    "updates",
    "via",
    "push"
  ],
  "task_keywords": [
    "send daily weather updates via a push notification using spontit",
    "cron",
    "send cron",
    "update cron",
    "openweathermap",
    "send openweathermap",
    "update openweathermap",
    "spontit",
    "send spontit",
    "update spontit",
