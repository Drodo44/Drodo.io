  },
  "name": "Uploading a file to a Slack channel",
  "description": "This workflow shows you how to post a message to a Slack channel and add a file attachment.",
  "category": "Communication",
  "tags": [
    "File Management",
    "manual",
    "Slack",
    "Manual Trigger",
    "uploading",
    "file",
    "slack",
    "channel",
    "workflow",
    "shows"
  ],
  "task_keywords": [
    "uploading a file to a slack channel",
    "manual",
    "slack",
    "manual trigger",
    "uploading file",
    "file slack",
    "slack channel",
    "channel workflow",
    "workflow shows",
    "shows you",
    "you post",
    "post message"
  ],
  "required_services": [
    "manual",
    "Slack"
  ],
  "triggers": [
    "Manual Trigger"
  ],
  "complexity": "simple",
  "workflow": {
    "nodes": [
      {
        "name": "On clicking 'execute'",
        "type": "n8n-nodes-base.manualTrigger",
        "position": [
          160,
          300
        ],
        "parameters": {},
        "typeVersion": 1
      },
      {
        "name": "Download the file",
        "type": "n8n-nodes-base.httpRequest",
        "position": [
          420,
          300
        ],
        "parameters": {
          "url": "https://n8n.io/_nuxt/img/sync-data-between-apps.a4be8c7.png",
          "options": {},
          "responseFormat": "file"
        },
        "typeVersion": 1
      },
      {
        "name": "Post to Slack",
        "type": "n8n-nodes-base.slack",
        "position": [
          640,
          300
        ],
        "parameters": {
          "options": {
            "channelIds": [
              "C02GP22NHJ6"
            ],
            "initialComment": "This is the file"
          },
          "resource": "file",
          "binaryData": true,
          "authentication": "oAuth2"
        },
        "credentials": {
          "slackOAuth2Api": {
            "id": "credential-id",
            "name": "slackOAuth2Api Credential"
          }
        },
        "typeVersion": 1
      }
    ],
    "connections": {
      "Download the file": {
        "main": [
          [
            {
              "node": "Post to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "On clicking 'execute'": {
        "main": [
          [
            {
              "node": "Download the file",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    }
  }
}
