  "complexity": "simple",
  "workflow": {
    "name": "Update ticket status from GitHub issue and send to Notion",
    "nodes": [
      {
        "id": "trigger-github-issue",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          93100
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "update-ticket-status-from-github-issue-and-send-to-notion",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-github-issue",
        "name": "Fetch data from GitHub issue",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          93100
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/github-issue",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-notion",
        "name": "Send to Notion",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          93100
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/notion",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-93100",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          93100
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from GitHub issue",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from GitHub issue": {
        "main": [
          {
            "node": "Send to Notion",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Notion": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
