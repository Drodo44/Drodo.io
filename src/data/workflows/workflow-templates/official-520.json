          300
        ],
        "parameters": {
          "text": "This is a test message",
          "subject": "Sample Subject",
          "toEmail": "user@example.com",
          "fromEmail": "user@example.com",
          "additionalFields": {}
        },
        "credentials": {
          "mailjetEmailApi": {
            "id": "credential-id",
            "name": "mailjetEmailApi Credential"
          }
        },
        "typeVersion": 1
      }
    ],
    "connections": {
      "On clicking 'execute'": {
        "main": [
          [
            {
              "node": "Mailjet",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
