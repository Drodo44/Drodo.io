  },
  "name": "auto-create-user-stories-from-feature-requirements",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: auto-create-user-stories-from-feature-requirements",
  "category": "AI",
  "tags": [
    "n8n advance",
    "function",
    "openai",
    "google Sheets",
    "webhook",
    "auto",
    "create",
    "user",
    "stories",
