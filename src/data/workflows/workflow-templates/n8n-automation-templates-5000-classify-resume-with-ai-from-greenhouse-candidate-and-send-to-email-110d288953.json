  "workflow": {
    "name": "Classify resume with ai from Greenhouse candidate and send to Email",
    "nodes": [
      {
        "id": "trigger-greenhouse-candidate",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          107500
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "classify-resume-with-ai-from-greenhouse-candidate-and-send-to-email",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-greenhouse-candidate",
        "name": "Fetch data from Greenhouse candidate",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          107500
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/greenhouse-candidate",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-classify-resume-with-ai",
        "name": "AI: Classify Resume With Ai",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          107500
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: classify resume with AI"
        }
      },
      {
        "id": "send-email",
        "name": "Send to Email",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          107500
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/email",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-107500",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          107500
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
