  },
  "name": "Run background check from Application form and send to Google Sheets",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Run background check from Application form and send to Google Sheets",
  "category": "Communication",
  "tags": [
    "n8n 2000 workflows",
    "slack",
    "webhook",
    "run",
    "background",
    "check",
    "application",
