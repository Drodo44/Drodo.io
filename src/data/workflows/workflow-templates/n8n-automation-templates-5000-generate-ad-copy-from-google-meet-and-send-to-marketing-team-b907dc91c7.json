  },
  "name": "Generate ad copy from Google Meet and send to Marketing team",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Generate ad copy from Google Meet and send to Marketing team",
  "category": "AI",
  "tags": [
    "n8n 2000 workflows",
    "open AIApi",
    "slack",
    "webhook",
    "generate",
    "copy",
    "google",
    "meet",
