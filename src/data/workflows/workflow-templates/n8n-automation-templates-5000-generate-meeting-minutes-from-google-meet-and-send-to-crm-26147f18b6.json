    "url": "https://github.com/ritik-prog/n8n-automation-templates-5000/blob/main/n8n_2000_workflows/generate-meeting-minutes-google-meet-crm.json"
  },
  "name": "Generate meeting minutes from Google Meet and send to CRM",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Generate meeting minutes from Google Meet and send to CRM",
  "category": "AI",
  "tags": [
    "n8n 2000 workflows",
    "open AIApi",
    "slack",
    "webhook",
    "generate",
    "meeting",
    "minutes",
    "google",
    "meet",
    "send"
  ],
  "task_keywords": [
    "generate meeting minutes from google meet and send to crm",
    "open aiapi",
    "send open aiapi",
    "slack",
    "send slack",
    "webhook",
    "generate meeting",
    "meeting minutes",
    "minutes google",
    "google meet",
    "meet send",
    "send crm"
  ],
  "required_services": [
    "open AIApi",
    "slack"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Generate meeting minutes from Google Meet and send to CRM",
    "nodes": [
      {
        "id": "trigger-google-meet",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          12000
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "generate-meeting-minutes-from-google-meet-and-send-to-crm",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-google-meet",
        "name": "Fetch data from Google Meet",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          12000
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/google-meet",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-generate-meeting-minutes",
        "name": "AI: Generate Meeting Minutes",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          12000
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: generate meeting minutes"
        }
      },
      {
        "id": "send-crm",
        "name": "Send to CRM",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          12000
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/crm",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-12000",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          12000
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Google Meet",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Google Meet": {
        "main": [
          {
            "node": "AI: Generate Meeting Minutes",
            "type": "main",
            "index": 0
          }
        ]
      },
      "AI: Generate Meeting Minutes": {
        "main": [
          [
            {
              "node": "AI: Generate Meeting Minutes",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Send to CRM": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
}
