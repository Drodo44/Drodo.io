    "nodes": [
      {
        "id": "trigger-airtable-campaign-table",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          75900
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "schedule-posts-from-airtable-campaign-table-and-send-to-facebook",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-airtable-campaign-table",
        "name": "Fetch data from Airtable campaign table",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          75900
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/airtable-campaign-table",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-facebook",
        "name": "Send to Facebook",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          75900
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/facebook",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-75900",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          75900
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Airtable campaign table",
              "type": "main",
              "index": 0
