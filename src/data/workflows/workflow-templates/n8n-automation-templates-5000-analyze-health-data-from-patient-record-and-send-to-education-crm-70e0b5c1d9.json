        "main": [
          [
            {
              "node": "AI: Analyze Health Data",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Send to Education CRM": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
