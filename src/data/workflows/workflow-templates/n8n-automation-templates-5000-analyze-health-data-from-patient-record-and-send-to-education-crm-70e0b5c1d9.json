  "workflow": {
    "name": "Analyze health data from Patient record and send to Education CRM",
    "nodes": [
      {
        "id": "trigger-patient-record",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          194000
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "analyze-health-data-from-patient-record-and-send-to-education-crm",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-patient-record",
        "name": "Fetch data from Patient record",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          194000
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/patient-record",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-analyze-health-data",
        "name": "AI: Analyze Health Data",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          194000
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: analyze health data"
        }
      },
      {
        "id": "send-education-crm",
        "name": "Send to Education CRM",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          194000
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/education-crm",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-194000",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          194000
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Patient record",
