    "firestore"
  ],
  "task_keywords": [
    "create, update, and get a document in google cloud firestore",
    "manual",
    "create manual",
    "update manual",
    "google cloud firestore",
    "create google cloud firestore",
    "update google cloud firestore",
    "edit fields (set)",
    "create edit fields (set)",
    "update edit fields (set)",
