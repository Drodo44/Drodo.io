  },
  "name": "Create social media posts from Content calendar and send to Instagram",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Create social media posts from Content calendar and send to Instagram",
  "category": "Marketing",
  "tags": [
    "n8n 2000 workflows",
    "slack",
    "webhook",
    "create",
    "social",
    "media",
    "posts",
    "content",
    "calendar"
  ],
  "task_keywords": [
    "create social media posts from content calendar and send to instagram",
    "slack",
    "send slack",
    "create slack",
    "webhook",
    "create social",
    "social media",
    "media posts",
    "posts content",
    "content calendar",
    "calendar send",
    "send instagram"
  ],
  "required_services": [
    "slack"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Create social media posts from Content calendar and send to Instagram",
    "nodes": [
      {
        "id": "trigger-content-calendar",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          55300
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "create-social-media-posts-from-content-calendar-and-send-to-instagram",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-content-calendar",
        "name": "Fetch data from Content calendar",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          55300
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/content-calendar",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-instagram",
        "name": "Send to Instagram",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          55300
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/instagram",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-55300",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          55300
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Content calendar",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Content calendar": {
        "main": [
          {
            "node": "Send to Instagram",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Instagram": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
}
