  "workflow": {
    "name": "Extract html elements from Website URL and send to Database",
    "nodes": [
      {
        "id": "trigger-website-url",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          199500
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "extract-html-elements-from-website-url-and-send-to-database",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-website-url",
        "name": "Fetch data from Website URL",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          199500
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/website-url",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-database",
        "name": "Send to Database",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          199500
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/database",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-199500",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          199500
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Website URL",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Website URL": {
        "main": [
          {
            "node": "Send to Database",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Database": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
