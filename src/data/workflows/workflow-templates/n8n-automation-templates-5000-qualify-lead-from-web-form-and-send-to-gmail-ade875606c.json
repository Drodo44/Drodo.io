  "complexity": "simple",
  "workflow": {
    "name": "Qualify lead from Web form and send to Gmail",
    "nodes": [
      {
        "id": "trigger-web-form",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          48100
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "qualify-lead-from-web-form-and-send-to-gmail",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-web-form",
        "name": "Fetch data from Web form",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          48100
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/web-form",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-gmail",
        "name": "Send to Gmail",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          48100
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/gmail",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-48100",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          48100
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Web form",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Web form": {
        "main": [
          {
            "node": "Send to Gmail",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Gmail": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
