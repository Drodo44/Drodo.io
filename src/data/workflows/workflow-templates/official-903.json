{
  "id": "official-903",
  "source": {
    "type": "official",
    "url": "https://n8n.io/workflows/903",
    "template_id": 903
  },
  "name": "Discover professional emails with uProc and send via Telegram",
  "description": "This n8n workflow template uses uProc's \"Get Email by Domain, Firstname and Lastname\" tool to discover a professional email address, and then sends that email to a Telegram channel .",
  "category": "AI",
  "tags": [
    "Lead Generation",
    "Telegram",
    "uProc",
    "Edit Fields (Set)",
    "Manual Trigger",
    "discover",
    "professional",
    "emails",
    "uproc",
    "send",
    "via"
  ],
  "task_keywords": [
    "discover professional emails with uproc and send via telegram",
    "telegram",
    "send telegram",
    "uproc",
    "send uproc",
    "edit fields (set)",
    "send edit fields (set)",
    "manual trigger",
    "discover professional",
    "professional emails",
    "emails uproc",
    "uproc send"
  ],
  "required_services": [
    "Telegram",
    "uProc",
    "Edit Fields (Set)"
  ],
  "triggers": [
    "Manual Trigger"
  ],
  "complexity": "simple",
  "workflow": {
    "id": "144",
    "name": "Discover Email",
    "nodes": [
      {
        "name": "On clicking 'execute'",
        "type": "n8n-nodes-base.manualTrigger",
        "position": [
          370,
          470
        ],
        "parameters": {},
        "typeVersion": 1
      },
      {
        "name": "Telegram",
        "type": "n8n-nodes-base.telegram",
        "position": [
          940,
          470
        ],
        "parameters": {
          "text": "=User {{$node[\"Get Email\"].json[\"params\"][\"firstname\"]}} {{$node[\"Get Email\"].json[\"params\"][\"lastname\"]}} has next email on {{$node[\"Get Email\"].json[\"params\"][\"domain\"]}}: {{$node[\"Get Email\"].json[\"message\"][\"email\"]}} ({{$node[\"Get Email\"].json[\"message\"][\"confidence\"]}} - {{$node[\"Get Email\"].json[\"message\"][\"score\"]}})",
          "chatId": "123456789",
          "additionalFields": {}
        },
        "credentials": {
          "telegramApi": {
            "id": "credential-id",
            "name": "telegramApi Credential"
          }
        },
        "typeVersion": 1
      },
      {
        "name": "Get Email",
        "type": "n8n-nodes-base.uproc",
        "position": [
          750,
          470
        ],
        "parameters": {
          "mode": "verify",
          "tool": "getEmailRecipient",
          "domain": "={{$node[\"Set Tool Parameters\"].json[\"domain\"]}}",
          "lastname": "={{$node[\"Set Tool Parameters\"].json[\"lastname\"]}}",
          "firstname": "={{$node[\"Set Tool Parameters\"].json[\"firstname\"]}}",
          "additionalOptions": {}
        },
        "credentials": {
          "uprocApi": {
            "id": "credential-id",
            "name": "uprocApi Credential"
          }
        },
        "typeVersion": 1
      },
      {
        "name": "Set Tool Parameters",
        "type": "n8n-nodes-base.set",
        "position": [
          570,
          470
        ],
        "parameters": {
          "values": {
            "string": [
              {
                "name": "firstname",
                "value": "Miquel"
              },
              {
                "name": "lastname",
                "value": "Colomer"
              },
              {
                "name": "domain",
                "value": "uproc.io"
              }
            ]
          },
          "options": {},
          "keepOnlySet": true
        },
        "typeVersion": 1
      }
    ],
    "active": false,
    "settings": {},
    "connections": {
      "Get Email": {
        "main": [
          [
            {
              "node": "Telegram",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Set Tool Parameters": {
        "main": [
          [
            {
              "node": "Get Email",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "On clicking 'execute'": {
        "main": [
          [
            {
              "node": "Set Tool Parameters",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    }
  }
}
