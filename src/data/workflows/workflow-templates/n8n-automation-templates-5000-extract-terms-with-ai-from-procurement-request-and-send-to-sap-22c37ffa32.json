  "workflow": {
    "name": "Extract terms with ai from Procurement request and send to SAP",
    "nodes": [
      {
        "id": "trigger-procurement-request",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          164000
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "extract-terms-with-ai-from-procurement-request-and-send-to-sap",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-procurement-request",
        "name": "Fetch data from Procurement request",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          164000
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/procurement-request",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-extract-terms-with-ai",
        "name": "AI: Extract Terms With Ai",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          164000
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: extract terms with AI"
        }
      },
      {
        "id": "send-sap",
        "name": "Send to SAP",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          164000
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/sap",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-164000",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          164000
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
