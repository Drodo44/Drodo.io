          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-inventory-sheet",
        "name": "Fetch data from Inventory sheet",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          173900
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/inventory-sheet",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-warehouse-system",
        "name": "Send to Warehouse system",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          173900
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/warehouse-system",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-173900",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          173900
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
