  "workflow": {
    "name": "Generate invoice pdf from Expense report and send to Accounting DB",
    "nodes": [
      {
        "id": "trigger-expense-report",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          127700
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "generate-invoice-pdf-from-expense-report-and-send-to-accounting-db",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-expense-report",
        "name": "Fetch data from Expense report",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          127700
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/expense-report",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-accounting-db",
        "name": "Send to Accounting DB",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          127700
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/accounting-db",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-127700",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          127700
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Expense report",
              "type": "main",
              "index": 0
            }
