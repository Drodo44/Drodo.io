  "name": "Get all the slides from a presentation and get thumbnails of pages",
  "description": "This workflow allows you to get all the slides from a presentation and get thumbnails of pages.",
  "category": "AI",
  "tags": [
    "Document Extraction",
    "manual",
    "Google Slides",
    "Manual Trigger",
    "all",
    "slides",
