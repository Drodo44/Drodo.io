      "AI: Generate Marketing Copy With Ai": {
        "main": [
          [
            {
              "node": "AI: Generate Marketing Copy With Ai",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Send to Mailchimp": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
