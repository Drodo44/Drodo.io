          60800
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: generate marketing copy with AI"
        }
      },
      {
        "id": "send-linkedin",
        "name": "Send to LinkedIn",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          60800
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/linkedin",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-60800",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          60800
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
