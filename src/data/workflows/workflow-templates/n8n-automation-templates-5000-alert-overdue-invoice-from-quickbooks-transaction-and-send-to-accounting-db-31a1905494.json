  "workflow": {
    "name": "Alert overdue invoice from QuickBooks transaction and send to Accounting DB",
    "nodes": [
      {
        "id": "trigger-quickbooks-transaction",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          134300
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "alert-overdue-invoice-from-quickbooks-transaction-and-send-to-accounting-db",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-quickbooks-transaction",
        "name": "Fetch data from QuickBooks transaction",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          134300
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/quickbooks-transaction",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-accounting-db",
        "name": "Send to Accounting DB",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          134300
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/accounting-db",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-134300",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          134300
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from QuickBooks transaction",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from QuickBooks transaction": {
        "main": [
          {
            "node": "Send to Accounting DB",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Accounting DB": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
