  "required_services": [
    "open AIApi",
    "slack"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Extract key decisions from Zoom and send to Email",
    "nodes": [
      {
        "id": "trigger-zoom",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          6300
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "extract-key-decisions-from-zoom-and-send-to-email",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-zoom",
        "name": "Fetch data from Zoom",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          6300
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/zoom",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-extract-key-decisions",
        "name": "AI: Extract Key Decisions",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          6300
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: extract key decisions"
        }
      },
      {
        "id": "send-email",
        "name": "Send to Email",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          6300
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/email",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-6300",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          6300
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Zoom",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Zoom": {
        "main": [
          {
            "node": "AI: Extract Key Decisions",
            "type": "main",
            "index": 0
          }
        ]
      },
      "AI: Extract Key Decisions": {
        "main": [
          [
            {
              "node": "AI: Extract Key Decisions",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Send to Email": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
}
