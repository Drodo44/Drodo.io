      },
      {
        "name": "FileMaker",
        "type": "n8n-nodes-base.filemaker",
        "position": [
          450,
          320
        ],
        "parameters": {
          "action": "create",
          "layout": "My Form Layout",
          "fieldsParametersUi": {
            "fields": [
              {
                "name": "first_name",
                "value": "Harshil"
              },
              {
                "name": "last_name",
                "value": "Agrawal"
              }
            ]
          }
