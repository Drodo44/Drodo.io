  },
  "name": "generate-competitor-analysis-reports-from-web-scraping",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: generate-competitor-analysis-reports-from-web-scraping",
  "category": "AI",
  "tags": [
    "n8n advance",
