  },
  "name": "auto-create-test-cases-from-user-requirements",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: auto-create-test-cases-from-user-requirements",
  "category": "AI",
  "tags": [
    "n8n advance",
