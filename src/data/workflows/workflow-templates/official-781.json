{
  "id": "official-781",
  "source": {
    "type": "official",
    "url": "https://n8n.io/workflows/781",
    "template_id": 781
  },
  "name": "Periodically send data from HTTP Request node to Telegram",
  "description": "Periodically send data from HTTP Request node to Telegram",
  "category": "Productivity",
  "tags": [
    "Personal Productivity",
    "Telegram",
    "Cron",
    "Cron Trigger",
    "periodically",
    "send",
    "data",
    "http",
    "request",
    "node"
  ],
  "task_keywords": [
    "periodically send data from http request node to telegram",
    "telegram",
    "send telegram",
    "cron",
    "send cron",
    "cron trigger",
    "periodically send",
    "send data",
    "data http",
    "http request",
    "request node",
    "node telegram"
  ],
  "required_services": [
    "Telegram",
    "Cron"
  ],
  "triggers": [
    "Cron Trigger"
  ],
  "complexity": "simple",
  "workflow": {
    "id": "57",
    "name": "Send a cocktail recipe every day via a Telegram",
    "nodes": [
      {
        "name": "Telegram",
        "type": "n8n-nodes-base.telegram",
        "position": [
          930,
          300
        ],
        "parameters": {
          "file": "={{$node[\"HTTP Request\"].json[\"drinks\"][0][\"strDrinkThumb\"]}}",
          "chatId": "123456789",
          "operation": "sendPhoto",
          "additionalFields": {
            "caption": "={{$node[\"HTTP Request\"].json[\"drinks\"][0][\"strInstructions\"]}}"
          }
        },
        "credentials": {
          "telegramApi": {
            "id": "credential-id",
            "name": "telegramApi Credential"
          }
        },
        "typeVersion": 1
      },
      {
        "name": "Cron",
        "type": "n8n-nodes-base.cron",
        "position": [
          530,
          300
        ],
        "parameters": {
          "triggerTimes": {
            "item": [
              {
                "hour": 20
              }
            ]
          }
        },
        "typeVersion": 1
      },
      {
        "name": "HTTP Request",
        "type": "n8n-nodes-base.httpRequest",
        "position": [
          730,
          300
        ],
        "parameters": {
          "url": "https://www.thecocktaildb.com/api/json/v1/1/random.php",
          "options": {}
        },
        "typeVersion": 1
      }
    ],
    "active": false,
    "settings": {},
    "connections": {
      "Cron": {
        "main": [
          [
            {
              "node": "HTTP Request",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "HTTP Request": {
        "main": [
          [
            {
              "node": "Telegram",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    }
  }
}
