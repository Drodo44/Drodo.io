  },
  "name": "Create, add an attachment, and send a draft using the Microsoft Outlook node",
  "description": "n8n workflow template from Danitilahun/n8n-workflow-templates: Create, add an attachment, and send a draft using the Microsoft Outlook node",
  "category": "Communication",
  "tags": [
    "workflows",
    "manual",
    "microsoft Outlook",
    "Manual Trigger",
    "create",
    "add",
    "attachment",
    "send",
    "draft",
