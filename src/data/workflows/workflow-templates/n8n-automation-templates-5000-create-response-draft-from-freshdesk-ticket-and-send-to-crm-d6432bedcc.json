  "complexity": "simple",
  "workflow": {
    "name": "Create response draft from Freshdesk ticket and send to CRM",
    "nodes": [
      {
        "id": "trigger-freshdesk-ticket",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          99500
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "create-response-draft-from-freshdesk-ticket-and-send-to-crm",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-freshdesk-ticket",
        "name": "Fetch data from Freshdesk ticket",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          99500
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/freshdesk-ticket",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-create-response-draft",
        "name": "AI: Create Response Draft",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          99500
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: create response draft"
        }
      },
      {
        "id": "send-crm",
        "name": "Send to CRM",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          99500
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/crm",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-99500",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          99500
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Freshdesk ticket",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Freshdesk ticket": {
        "main": [
          {
            "node": "AI: Create Response Draft",
            "type": "main",
            "index": 0
          }
        ]
      },
      "AI: Create Response Draft": {
        "main": [
          [
            {
              "node": "AI: Create Response Draft",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Send to CRM": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
