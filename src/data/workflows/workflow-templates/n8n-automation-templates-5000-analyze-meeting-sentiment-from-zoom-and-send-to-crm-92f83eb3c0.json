  },
  "name": "Analyze meeting sentiment from Zoom and send to CRM",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Analyze meeting sentiment from Zoom and send to CRM",
  "category": "AI",
  "tags": [
    "n8n 2000 workflows",
    "open AIApi",
    "slack",
    "webhook",
    "analyze",
    "meeting",
    "sentiment",
    "zoom",
    "send",
    "crm"
  ],
  "task_keywords": [
    "analyze meeting sentiment from zoom and send to crm",
    "open aiapi",
    "send open aiapi",
    "slack",
    "send slack",
    "webhook",
    "analyze meeting",
    "meeting sentiment",
    "sentiment zoom",
    "zoom send",
    "send crm",
    "crm n8n"
  ],
  "required_services": [
    "open AIApi",
    "slack"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Analyze meeting sentiment from Zoom and send to CRM",
    "nodes": [
      {
        "id": "trigger-zoom",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          4000
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "analyze-meeting-sentiment-from-zoom-and-send-to-crm",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-zoom",
        "name": "Fetch data from Zoom",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          4000
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/zoom",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-analyze-meeting-sentiment",
        "name": "AI: Analyze Meeting Sentiment",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          4000
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: analyze meeting sentiment"
        }
      },
      {
        "id": "send-crm",
        "name": "Send to CRM",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          4000
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/crm",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-4000",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          4000
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Zoom",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Zoom": {
        "main": [
          {
            "node": "AI: Analyze Meeting Sentiment",
            "type": "main",
            "index": 0
          }
        ]
      },
      "AI: Analyze Meeting Sentiment": {
        "main": [
          [
            {
              "node": "AI: Analyze Meeting Sentiment",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Send to CRM": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
}
