{
  "id": "official-615",
  "source": {
    "type": "official",
    "url": "https://n8n.io/workflows/615",
    "template_id": 615
  },
  "name": "Manage folders automatically in Dropbox",
  "description": "Companion workflow for Dropbox node docs",
  "category": "Productivity",
  "tags": [
    "File Management",
    "manual",
    "Dropbox",
    "Manual Trigger",
    "manage",
    "folders",
    "automatically",
    "dropbox",
    "companion",
    "workflow"
  ],
  "task_keywords": [
    "manage folders automatically in dropbox",
    "manual",
    "dropbox",
    "manual trigger",
    "manage folders",
    "folders automatically",
    "automatically dropbox",
    "dropbox companion",
    "companion workflow",
    "workflow dropbox",
    "dropbox node",
    "node docs"
  ],
  "required_services": [
    "manual",
    "Dropbox"
  ],
  "triggers": [
    "Manual Trigger"
  ],
  "complexity": "simple",
  "workflow": {
    "nodes": [
      {
        "name": "On clicking 'execute'",
        "type": "n8n-nodes-base.manualTrigger",
        "position": [
          50,
          200
        ],
        "parameters": {},
        "typeVersion": 1
      },
      {
        "name": "Dropbox",
        "type": "n8n-nodes-base.dropbox",
        "position": [
          250,
          200
        ],
        "parameters": {
          "path": "/n8n",
          "resource": "folder"
        },
        "credentials": {
          "dropboxApi": "dropbox_accesstoken"
        },
        "typeVersion": 1
      },
      {
        "name": "Dropbox1",
        "type": "n8n-nodes-base.dropbox",
        "position": [
          650,
          200
        ],
        "parameters": {
          "path": "/n8n/file.png",
          "binaryData": true
        },
        "credentials": {
          "dropboxApi": "dropbox_accesstoken"
        },
        "typeVersion": 1
      },
      {
        "name": "HTTP Request",
        "type": "n8n-nodes-base.httpRequest",
        "position": [
          450,
          200
        ],
        "parameters": {
          "url": "https://n8n.io/n8n-logo.png",
          "options": {},
          "responseFormat": "file"
        },
        "typeVersion": 1
      },
      {
        "name": "Dropbox2",
        "type": "n8n-nodes-base.dropbox",
        "position": [
          850,
          200
        ],
        "parameters": {
          "path": "/n8n",
          "resource": "folder",
          "operation": "list"
        },
        "credentials": {
          "dropboxApi": "dropbox_accesstoken"
        },
        "typeVersion": 1
      }
    ],
    "connections": {
      "Dropbox": {
        "main": [
          [
            {
              "node": "HTTP Request",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Dropbox1": {
        "main": [
          [
            {
              "node": "Dropbox2",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "HTTP Request": {
        "main": [
          [
            {
              "node": "Dropbox1",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "On clicking 'execute'": {
        "main": [
          [
            {
              "node": "Dropbox",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    }
  }
}
