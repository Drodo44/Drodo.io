{
  "id": "official-434",
  "source": {
    "type": "official",
    "url": "https://n8n.io/workflows/434",
    "template_id": 434
  },
  "name": "Extract post titles from a blog",
  "description": "This workflow uses n8n to extract the names of all the posts from the Hackernoon homepage.",
  "category": "Other",
  "tags": [
    "Market Research",
    "manual",
    "HTML Extract",
    "Manual Trigger",
    "extract",
    "post",
    "titles",
    "blog",
    "workflow",
    "uses"
  ],
  "task_keywords": [
    "extract post titles from a blog",
    "manual",
    "html extract",
    "manual trigger",
    "extract post",
    "post titles",
    "titles blog",
    "blog workflow",
    "workflow uses",
    "uses n8n",
    "n8n extract",
    "extract names"
  ],
  "required_services": [
    "manual",
    "HTML Extract"
  ],
  "triggers": [
    "Manual Trigger"
  ],
  "complexity": "simple",
  "workflow": {
    "nodes": [
      {
        "name": "On clicking 'execute'",
        "type": "n8n-nodes-base.manualTrigger",
        "position": [
          250,
          300
        ],
        "parameters": {},
        "typeVersion": 1
      },
      {
        "name": "HTTP Request",
        "type": "n8n-nodes-base.httpRequest",
        "position": [
          450,
          300
        ],
        "parameters": {
          "url": "https://hackernoon.com/",
          "options": {},
          "responseFormat": "string"
        },
        "typeVersion": 1
      },
      {
        "name": "HTML Extract",
        "type": "n8n-nodes-base.htmlExtract",
        "position": [
          650,
          300
        ],
        "parameters": {
          "options": {},
          "extractionValues": {
            "values": [
              {
                "key": "item",
                "cssSelector": "h2",
                "returnArray": true,
                "returnValue": "html"
              }
            ]
          }
        },
        "typeVersion": 1
      },
      {
        "name": "HTML Extract1",
        "type": "n8n-nodes-base.htmlExtract",
        "position": [
          850,
          300
        ],
        "parameters": {
          "options": {},
          "dataPropertyName": "item",
          "extractionValues": {
            "values": [
              {
                "key": "title",
                "cssSelector": "a"
              },
              {
                "key": "url",
                "attribute": "href",
                "cssSelector": "a",
                "returnValue": "attribute"
              }
            ]
          }
        },
        "typeVersion": 1
      }
    ],
    "connections": {
      "HTML Extract": {
        "main": [
          [
            {
              "node": "HTML Extract1",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "HTTP Request": {
        "main": [
          [
            {
              "node": "HTML Extract",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "On clicking 'execute'": {
        "main": [
          [
            {
              "node": "HTTP Request",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    }
  }
}
