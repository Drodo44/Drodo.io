  "workflow": {
    "name": "Generate marketing copy with ai from Content calendar and send to Instagram",
    "nodes": [
      {
        "id": "trigger-content-calendar",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          56100
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "generate-marketing-copy-with-ai-from-content-calendar-and-send-to-instagram",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-content-calendar",
        "name": "Fetch data from Content calendar",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          56100
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/content-calendar",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-generate-marketing-copy-with-ai",
        "name": "AI: Generate Marketing Copy With Ai",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          56100
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: generate marketing copy with AI"
        }
      },
      {
        "id": "send-instagram",
        "name": "Send to Instagram",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          56100
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/instagram",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-56100",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          56100
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
