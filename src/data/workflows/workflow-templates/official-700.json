  ],
  "triggers": [
    "Manual Trigger",
    "Cron Trigger"
  ],
  "complexity": "simple",
  "workflow": {
    "id": "60",
    "name": "n8n_mysql_purge_history_greater_than_10_days",
    "nodes": [
      {
        "name": "On clicking 'execute'",
        "type": "n8n-nodes-base.manualTrigger",
        "position": [
          250,
          300
        ],
        "parameters": {},
        "typeVersion": 1
      },
      {
        "name": "MySQL",
        "type": "n8n-nodes-base.mySql",
        "position": [
          450,
          300
        ],
        "parameters": {
          "query": "DELETE FROM execution_entity \nWHERE DATE(stoppedAt) < DATE_SUB(CURDATE(), INTERVAL 30 DAY)",
          "operation": "executeQuery"
        },
        "credentials": {
          "mySql": "n8n"
        },
        "typeVersion": 1
      },
      {
        "name": "Cron",
        "type": "n8n-nodes-base.cron",
        "position": [
          250,
          460
        ],
        "parameters": {
          "triggerTimes": {
            "item": [
              {
                "hour": 7
              }
            ]
          }
        },
        "typeVersion": 1
      }
    ],
    "active": true,
    "settings": {},
    "connections": {
      "Cron": {
        "main": [
          [
            {
              "node": "MySQL",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "On clicking 'execute'": {
        "main": [
          [
            {
              "node": "MySQL",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    }
  }
}
