    "mysql"
  ],
  "task_keywords": [
    "purge n8n execution history located in mysql",
    "manual",
    "mysql",
    "cron",
    "manual trigger",
    "cron trigger",
    "purge n8n",
    "n8n execution",
    "execution history",
    "history located",
