  },
  "name": "Classify ticket with ai from GitHub issue and send to Slack",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Classify ticket with ai from GitHub issue and send to Slack",
  "category": "AI",
  "tags": [
    "n8n 2000 workflows",
    "open AIApi",
    "slack",
    "webhook",
    "classify",
    "ticket",
    "github",
    "issue",
