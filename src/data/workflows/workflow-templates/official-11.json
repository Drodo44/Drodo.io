{
  "id": "official-11",
  "source": {
    "type": "official",
    "url": "https://n8n.io/workflows/11",
    "template_id": 11
  },
  "name": "Add data from Google Sheet to Dropbox",
  "description": "1.",
  "category": "Data",
  "tags": [
    "File Management",
    "Google Sheets",
    "Spreadsheet File",
    "Dropbox",
    "Interval",
    "add",
    "data",
    "google",
    "sheet",
    "dropbox"
  ],
  "task_keywords": [
    "add data from google sheet to dropbox",
    "google sheets",
    "spreadsheet file",
    "dropbox",
    "interval",
    "add data",
    "data google",
    "google sheet",
    "sheet dropbox"
  ],
  "required_services": [
    "Google Sheets",
    "Spreadsheet File",
    "Dropbox",
    "Interval"
  ],
  "triggers": [],
  "complexity": "simple",
  "workflow": {
    "nodes": [
      {
        "name": "Read Sheet",
        "type": "n8n-nodes-base.googleSheets",
        "position": [
          450,
          300
        ],
        "parameters": {
          "sheetId": "1GT2dc0dOkAC1apY0UlTKY9vitBl8PtKrILvFiAy5VBs"
        },
        "credentials": {
          "googleApi": ""
        },
        "typeVersion": 1
      },
      {
        "name": "Convert to XLS",
        "type": "n8n-nodes-base.spreadsheetFile",
        "position": [
          650,
          300
        ],
        "parameters": {
          "operation": "toFile"
        },
        "typeVersion": 1
      },
      {
        "name": "Upload Dropbox",
        "type": "n8n-nodes-base.dropbox",
        "position": [
          850,
          300
        ],
        "parameters": {
          "path": "/my-sheets/prices.xls",
          "binaryData": true
        },
        "credentials": {
          "dropboxApi": ""
        },
        "typeVersion": 1
      },
      {
        "name": "Trigger all 15 min",
        "type": "n8n-nodes-base.interval",
        "position": [
          250,
          300
        ],
        "parameters": {
          "unit": "minutes",
          "interval": 15
        },
        "typeVersion": 1
      }
    ],
    "connections": {
      "Read Sheet": {
        "main": [
          [
            {
              "node": "Convert to XLS",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Convert to XLS": {
        "main": [
          [
            {
              "node": "Upload Dropbox",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Trigger all 15 min": {
        "main": [
          [
            {
              "node": "Read Sheet",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    }
  }
}
