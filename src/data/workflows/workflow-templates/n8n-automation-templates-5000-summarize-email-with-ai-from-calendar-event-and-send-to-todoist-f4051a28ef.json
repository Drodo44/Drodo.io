          [
            {
              "node": "AI: Summarize Email With Ai",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Send to Todoist": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
