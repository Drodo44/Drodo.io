  },
  "name": "Schedule posts from Content calendar and send to Google Ads",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Schedule posts from Content calendar and send to Google Ads",
  "category": "Communication",
  "tags": [
    "n8n 2000 workflows",
    "slack",
    "webhook",
    "schedule",
    "posts",
    "content",
    "calendar",
    "send",
    "google"
  ],
  "task_keywords": [
    "schedule posts from content calendar and send to google ads",
    "slack",
    "send slack",
    "webhook",
    "schedule posts",
    "posts content",
    "content calendar",
    "calendar send",
    "send google",
    "google ads",
    "ads n8n",
    "n8n workflow"
  ],
  "required_services": [
    "slack"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Schedule posts from Content calendar and send to Google Ads",
    "nodes": [
      {
        "id": "trigger-content-calendar",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          57300
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "schedule-posts-from-content-calendar-and-send-to-google-ads",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-content-calendar",
        "name": "Fetch data from Content calendar",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          57300
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/content-calendar",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-google-ads",
        "name": "Send to Google Ads",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          57300
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/google-ads",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-57300",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          57300
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Content calendar",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Content calendar": {
        "main": [
          {
            "node": "Send to Google Ads",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Google Ads": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
}
