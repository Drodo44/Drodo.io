            "type": "main",
            "index": 0
          }
        ]
      },
      "AI: Create Daily Report": {
        "main": [
          [
            {
              "node": "AI: Create Daily Report",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Send to Notion": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
