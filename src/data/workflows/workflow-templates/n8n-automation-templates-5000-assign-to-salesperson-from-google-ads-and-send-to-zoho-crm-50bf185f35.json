  },
  "name": "Assign to salesperson from Google Ads and send to Zoho CRM",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Assign to salesperson from Google Ads and send to Zoho CRM",
  "category": "Sales",
  "tags": [
    "n8n 2000 workflows",
    "slack",
    "webhook",
    "assign",
    "salesperson",
    "google",
    "ads",
    "send",
    "zoho"
  ],
  "task_keywords": [
    "assign to salesperson from google ads and send to zoho crm",
    "slack",
    "send slack",
    "webhook",
    "assign salesperson",
    "salesperson google",
    "google ads",
    "ads send",
    "send zoho",
    "zoho crm",
    "crm n8n",
    "n8n workflow"
  ],
  "required_services": [
    "slack"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Assign to salesperson from Google Ads and send to Zoho CRM",
    "nodes": [
      {
        "id": "trigger-google-ads",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          40100
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "assign-to-salesperson-from-google-ads-and-send-to-zoho-crm",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-google-ads",
        "name": "Fetch data from Google Ads",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          40100
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/google-ads",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-zoho-crm",
        "name": "Send to Zoho CRM",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          40100
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/zoho-crm",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-40100",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          40100
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Google Ads",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Google Ads": {
        "main": [
          {
            "node": "Send to Zoho CRM",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Zoho CRM": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
}
