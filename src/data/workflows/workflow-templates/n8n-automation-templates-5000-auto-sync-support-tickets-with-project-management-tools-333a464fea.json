  "name": "auto-sync-support-tickets-with-project-management-tools",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: auto-sync-support-tickets-with-project-management-tools",
  "category": "Support",
  "tags": [
    "n8n advance",
