  },
  "name": "personalized-email-campaign-customer-behavior",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: personalized-email-campaign-customer-behavior",
  "category": "AI",
  "tags": [
    "n8n advance",
    "customer Behavior",
    "function",
    "crm",
    "openai",
    "smtp",
    "personalized",
    "email",
    "campaign",
