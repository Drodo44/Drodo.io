  ],
  "complexity": "simple",
  "workflow": {
    "name": "Sync with github from Asana task and send to GitHub",
    "nodes": [
      {
        "id": "trigger-asana-task",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          152200
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "sync-with-github-from-asana-task-and-send-to-github",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-asana-task",
        "name": "Fetch data from Asana task",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          152200
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/asana-task",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-github",
        "name": "Send to GitHub",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          152200
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/github",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-152200",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          152200
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Asana task",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Asana task": {
        "main": [
          {
            "node": "Send to GitHub",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to GitHub": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
