    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Generate invoice pdf from Invoice sheet and send to QuickBooks",
    "nodes": [
      {
        "id": "trigger-invoice-sheet",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          120300
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "generate-invoice-pdf-from-invoice-sheet-and-send-to-quickbooks",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-invoice-sheet",
        "name": "Fetch data from Invoice sheet",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          120300
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/invoice-sheet",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-quickbooks",
        "name": "Send to QuickBooks",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          120300
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/quickbooks",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-120300",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          120300
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Invoice sheet",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Invoice sheet": {
        "main": [
          {
            "node": "Send to QuickBooks",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to QuickBooks": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
