  "workflow": {
    "name": "Notify legal team from Contract document and send to Compliance DB",
    "nodes": [
      {
        "id": "trigger-contract-document",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          162300
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "notify-legal-team-from-contract-document-and-send-to-compliance-db",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-contract-document",
        "name": "Fetch data from Contract document",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          162300
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/contract-document",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-compliance-db",
        "name": "Send to Compliance DB",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          162300
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/compliance-db",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-162300",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          162300
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Contract document",
              "type": "main",
              "index": 0
            }
