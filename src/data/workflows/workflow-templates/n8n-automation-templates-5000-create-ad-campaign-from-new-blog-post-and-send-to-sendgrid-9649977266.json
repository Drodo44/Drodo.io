  "workflow": {
    "name": "Create ad campaign from New blog post and send to SendGrid",
    "nodes": [
      {
        "id": "trigger-new-blog-post",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          64300
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "create-ad-campaign-from-new-blog-post-and-send-to-sendgrid",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-new-blog-post",
        "name": "Fetch data from New blog post",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          64300
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/new-blog-post",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-sendgrid",
        "name": "Send to SendGrid",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          64300
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/sendgrid",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-64300",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          64300
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from New blog post",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from New blog post": {
        "main": [
