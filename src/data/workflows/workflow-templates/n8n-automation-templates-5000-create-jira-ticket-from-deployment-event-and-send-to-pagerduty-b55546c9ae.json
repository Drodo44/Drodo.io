  "workflow": {
    "name": "Create jira ticket from Deployment event and send to PagerDuty",
    "nodes": [
      {
        "id": "trigger-deployment-event",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          149800
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "create-jira-ticket-from-deployment-event-and-send-to-pagerduty",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-deployment-event",
        "name": "Fetch data from Deployment event",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          149800
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/deployment-event",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-pagerduty",
        "name": "Send to PagerDuty",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          149800
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/pagerduty",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-149800",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          149800
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Deployment event",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Deployment event": {
        "main": [
          {
            "node": "Send to PagerDuty",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to PagerDuty": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
