        "typeVersion": 1
      },
      {
        "name": "move binary data ",
        "type": "n8n-nodes-base.moveBinaryData",
        "position": [
          800,
          140
        ],
        "parameters": {
          "options": {}
        },
        "typeVersion": 1
      },
      {
        "name": "Note6",
        "type": "n8n-nodes-base.stickyNote",
        "position": [
          200,
