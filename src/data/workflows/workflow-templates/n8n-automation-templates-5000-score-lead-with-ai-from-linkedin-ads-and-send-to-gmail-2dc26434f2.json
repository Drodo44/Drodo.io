  "complexity": "simple",
  "workflow": {
    "name": "Score lead with ai from LinkedIn Ads and send to Gmail",
    "nodes": [
      {
        "id": "trigger-linkedin-ads",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          43200
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "score-lead-with-ai-from-linkedin-ads-and-send-to-gmail",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-linkedin-ads",
        "name": "Fetch data from LinkedIn Ads",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          43200
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/linkedin-ads",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-score-lead-with-ai",
        "name": "AI: Score Lead With Ai",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          43200
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: score lead with AI"
        }
      },
      {
        "id": "send-gmail",
        "name": "Send to Gmail",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          43200
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/gmail",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-43200",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          43200
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
