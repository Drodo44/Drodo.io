  },
  "name": "Add lead to crm from Facebook Ads and send to HubSpot",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Add lead to crm from Facebook Ads and send to HubSpot",
  "category": "Communication",
  "tags": [
    "n8n 2000 workflows",
    "slack",
