        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/sharepoint",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-166800",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          166800
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
