          166800
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/procurement-request",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-sharepoint",
        "name": "Send to SharePoint",
        "type": "n8n-nodes-base.httpRequest",
