  "workflow": {
    "name": "Notify legal team from Contract document and send to SharePoint",
    "nodes": [
      {
        "id": "trigger-contract-document",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          162000
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "notify-legal-team-from-contract-document-and-send-to-sharepoint",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-contract-document",
        "name": "Fetch data from Contract document",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          162000
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/contract-document",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-sharepoint",
        "name": "Send to SharePoint",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          162000
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/sharepoint",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-162000",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          162000
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Contract document",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Contract document": {
        "main": [
          {
            "node": "Send to SharePoint",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to SharePoint": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
