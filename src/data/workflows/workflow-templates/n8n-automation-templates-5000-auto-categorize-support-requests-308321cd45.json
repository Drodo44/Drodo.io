{
  "id": "n8n-automation-templates-5000-auto-categorize-support-requests-308321cd45",
  "source": {
    "type": "github",
    "repository": "ritik-prog/n8n-automation-templates-5000",
    "repository_stars": 341,
    "path": "n8n advance/auto-categorize-support-requests.json",
    "url": "https://github.com/ritik-prog/n8n-automation-templates-5000/blob/main/n8n advance/auto-categorize-support-requests.json"
  },
  "name": "auto-categorize-support-requests",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: auto-categorize-support-requests",
  "category": "AI",
  "tags": [
    "n8n advance",
    "function",
    "openai",
    "google Sheets",
    "webhook",
    "auto",
    "categorize",
    "support",
    "requests",
    "n8n",
    "workflow"
  ],
  "task_keywords": [
    "auto-categorize-support-requests",
    "function",
    "openai",
    "google sheets",
    "webhook",
    "auto categorize",
    "categorize support",
    "support requests",
    "requests n8n",
    "n8n workflow",
    "workflow template",
    "template ritik"
  ],
  "required_services": [
    "function",
    "openai",
    "google Sheets"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "auto-categorize-support-requests",
    "nodes": [
      {
        "parameters": {
          "httpMethod": "POST",
          "path": "incoming-support-request"
        },
        "id": "1",
        "name": "Support Request Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          100,
          300
        ],
        "webhookId": "support-request-hook"
      },
      {
        "parameters": {
          "functionCode": "return [{ json: { email: $json.body.email, message: $json.body.message } }];"
        },
        "id": "2",
        "name": "Extract Request Content",
        "type": "n8n-nodes-base.function",
        "typeVersion": 1,
        "position": [
          300,
          300
        ]
      },
      {
        "parameters": {
          "model": "gpt-4",
          "temperature": 0.3,
          "messages": [
            {
              "role": "system",
              "content": "You are a support assistant. Categorize the message into one of the following categories: 'Billing', 'Technical Issue', 'Feature Request', 'General Inquiry'. Also suggest 2–3 tags. Respond in JSON: {category, tags}"
            },
            {
              "role": "user",
              "content": "{{$json.message}}"
            }
          ]
        },
        "id": "3",
        "name": "Categorize & Tag (GPT-4)",
        "type": "n8n-nodes-base.openai",
        "typeVersion": 1,
        "position": [
          500,
          300
        ],
        "credentials": {
          "openAiApi": {
            "id": "openai_credential",
            "name": "OpenAI API"
          }
        }
      },
      {
        "parameters": {
          "functionCode": "\nconst parsed = JSON.parse($json.choices[0].message.content);\nreturn [{\n  json: {\n    email: $json.email,\n    category: parsed.category,\n    tags: parsed.tags\n  }\n}];\n"
        },
        "id": "4",
        "name": "Parse GPT Tags",
        "type": "n8n-nodes-base.function",
        "typeVersion": 1,
        "position": [
          700,
          300
        ]
      },
      {
        "parameters": {
          "sheetId": "support-categorization-log-id",
          "range": "SupportRequests!A1",
          "valueInputMode": "USER_ENTERED",
          "fields": [
            "={{$json.email}}",
            "={{$json.category}}",
            "={{$json.tags}}"
          ]
        },
        "id": "5",
        "name": "Log to Google Sheet",
        "type": "n8n-nodes-base.googleSheets",
        "typeVersion": 1,
        "position": [
          900,
          300
        ],
        "credentials": {
          "googleSheetsOAuth2Api": {
            "id": "google_sheets_credential",
            "name": "Google Sheets"
          }
        }
      }
    ],
    "connections": {
      "Support Request Trigger": {
        "main": [
          [
            {
              "node": "Extract Request Content",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Extract Request Content": {
        "main": [
          [
            {
              "node": "Categorize & Tag (GPT-4)",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Categorize & Tag (GPT-4)": {
        "main": [
          [
            {
              "node": "Parse GPT Tags",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Parse GPT Tags": {
        "main": [
          [
            {
              "node": "Log to Google Sheet",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "active": false
  }
}
