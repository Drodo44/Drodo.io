    "template_id": 652
  },
  "name": "Store data received from webhook in JSON",
  "description": "Store the data received from the CocktailDB API in JSON",
  "category": "AI",
  "tags": [
    "File Management",
    "manual",
    "Convert to/from binary data",
    "Write Binary File",
    "Manual Trigger",
    "store",
    "data",
    "received",
    "webhook",
    "json"
  ],
  "task_keywords": [
    "store data received from webhook in json",
    "manual",
    "convert to/from binary data",
    "write binary file",
    "manual trigger",
    "store data",
    "data received",
    "received webhook",
    "webhook json",
    "json store",
    "received cocktaildb",
    "cocktaildb json"
  ],
  "required_services": [
    "manual",
    "Convert to/from binary data",
    "Write Binary File"
  ],
  "triggers": [
    "Manual Trigger"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Store the data received from the CocktailDB API in JSON",
    "nodes": [
      {
        "name": "On clicking 'execute'",
        "type": "n8n-nodes-base.manualTrigger",
        "position": [
          250,
          300
        ],
        "parameters": {},
        "typeVersion": 1
      },
      {
        "name": "HTTP Request",
        "type": "n8n-nodes-base.httpRequest",
        "position": [
          400,
          300
        ],
        "parameters": {
          "url": "https://www.thecocktaildb.com/api/json/v1/1/random.php",
          "options": {}
        },
        "typeVersion": 1
      },
      {
        "name": "Move Binary Data",
        "type": "n8n-nodes-base.moveBinaryData",
        "position": [
          550,
          300
        ],
        "parameters": {
          "mode": "jsonToBinary",
          "options": {}
        },
        "typeVersion": 1
      },
      {
        "name": "Write Binary File",
        "type": "n8n-nodes-base.writeBinaryFile",
        "position": [
          700,
          300
        ],
        "parameters": {
          "fileName": "cocktail.json"
        },
        "typeVersion": 1
      }
    ],
    "active": false,
    "settings": {},
    "connections": {
      "HTTP Request": {
        "main": [
          [
            {
              "node": "Move Binary Data",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Move Binary Data": {
        "main": [
          [
            {
              "node": "Write Binary File",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "On clicking 'execute'": {
        "main": [
          [
            {
              "node": "HTTP Request",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    }
  }
}
