  },
  "name": "Capture lead from Google Ads and send to Pipedrive",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Capture lead from Google Ads and send to Pipedrive",
  "category": "Communication",
  "tags": [
    "n8n 2000 workflows",
    "slack",
    "webhook",
    "capture",
    "lead",
    "google",
    "ads",
    "send",
    "pipedrive"
  ],
  "task_keywords": [
    "capture lead from google ads and send to pipedrive",
    "slack",
    "send slack",
    "webhook",
    "capture lead",
    "lead google",
    "google ads",
    "ads send",
    "send pipedrive",
    "pipedrive n8n",
    "n8n workflow",
    "workflow template"
  ],
  "required_services": [
    "slack"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Capture lead from Google Ads and send to Pipedrive",
    "nodes": [
      {
        "id": "trigger-google-ads",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          35800
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "capture-lead-from-google-ads-and-send-to-pipedrive",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-google-ads",
        "name": "Fetch data from Google Ads",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          35800
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/google-ads",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-pipedrive",
        "name": "Send to Pipedrive",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          35800
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/pipedrive",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-35800",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          35800
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Google Ads",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Google Ads": {
        "main": [
          {
            "node": "Send to Pipedrive",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Pipedrive": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
}
