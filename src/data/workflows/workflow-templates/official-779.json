    "name": "Create, update, and get an entry in Strapi",
    "nodes": [
      {
        "name": "On clicking 'execute'",
        "type": "n8n-nodes-base.manualTrigger",
        "position": [
          250,
          300
        ],
        "parameters": {},
        "typeVersion": 1
      },
      {
        "name": "Strapi",
        "type": "n8n-nodes-base.strapi",
        "position": [
