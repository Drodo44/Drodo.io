  },
  "name": "Analyze meeting sentiment from Zoom and send to Google Sheets",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Analyze meeting sentiment from Zoom and send to Google Sheets",
  "category": "AI",
  "tags": [
    "n8n 2000 workflows",
    "open AIApi",
    "slack",
    "webhook",
    "analyze",
    "meeting",
    "sentiment",
    "zoom",
