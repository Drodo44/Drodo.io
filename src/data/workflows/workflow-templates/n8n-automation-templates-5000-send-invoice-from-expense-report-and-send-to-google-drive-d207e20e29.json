    "url": "https://github.com/ritik-prog/n8n-automation-templates-5000/blob/main/n8n_2000_workflows/send-invoice-expense-report-google-drive.json"
  },
  "name": "Send invoice from Expense report and send to Google Drive",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Send invoice from Expense report and send to Google Drive",
  "category": "Communication",
  "tags": [
    "n8n 2000 workflows",
    "slack",
    "webhook",
    "send",
    "invoice",
    "expense",
    "report",
    "google"
  ],
  "task_keywords": [
    "send invoice from expense report and send to google drive",
    "slack",
    "send slack",
    "webhook",
    "send invoice",
    "invoice expense",
    "expense report",
    "report send",
    "send google",
    "google drive",
    "drive n8n",
    "n8n workflow"
  ],
  "required_services": [
    "slack"
  ],
  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Send invoice from Expense report and send to Google Drive",
    "nodes": [
      {
        "id": "trigger-expense-report",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          128000
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "send-invoice-from-expense-report-and-send-to-google-drive",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-expense-report",
        "name": "Fetch data from Expense report",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          128000
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/expense-report",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-google-drive",
        "name": "Send to Google Drive",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          128000
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/google-drive",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-128000",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          128000
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Expense report",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Expense report": {
        "main": [
          {
            "node": "Send to Google Drive",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Google Drive": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
}
