      },
      {
        "id": "fetch-linkedin-ads",
        "name": "Fetch data from LinkedIn Ads",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          45300
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/linkedin-ads",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-gmail",
        "name": "Send to Gmail",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          45300
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/gmail",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-45300",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          45300
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
