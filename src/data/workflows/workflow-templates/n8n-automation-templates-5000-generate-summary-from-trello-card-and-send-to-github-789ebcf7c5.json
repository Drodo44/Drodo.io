  },
  "name": "Generate summary from Trello card and send to GitHub",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Generate summary from Trello card and send to GitHub",
  "category": "AI",
  "tags": [
    "n8n 2000 workflows",
    "open AIApi",
    "slack",
