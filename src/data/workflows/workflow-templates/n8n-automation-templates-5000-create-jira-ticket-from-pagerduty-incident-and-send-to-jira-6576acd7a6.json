  "complexity": "simple",
  "workflow": {
    "name": "Create jira ticket from PagerDuty incident and send to Jira",
    "nodes": [
      {
        "id": "trigger-pagerduty-incident",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          142300
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "create-jira-ticket-from-pagerduty-incident-and-send-to-jira",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-pagerduty-incident",
        "name": "Fetch data from PagerDuty incident",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          142300
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/pagerduty-incident",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-jira",
        "name": "Send to Jira",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          142300
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/jira",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-142300",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          142300
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from PagerDuty incident",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from PagerDuty incident": {
        "main": [
          {
            "node": "Send to Jira",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Jira": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
