    "template_id": 863
  },
  "name": "Verify a phone number with uProc",
  "description": "Do you want to avoid communication problems when launching phone calls?",
  "category": "Communication",
  "tags": [
    "Lead Generation",
    "manual",
    "Function Item",
    "uProc",
    "Manual Trigger",
    "verify",
    "phone",
    "number",
    "uproc",
    "you",
    "want"
  ],
  "task_keywords": [
    "verify a phone number with uproc",
    "manual",
    "function item",
    "uproc",
    "manual trigger",
    "verify phone",
    "phone number",
    "number uproc",
    "uproc you",
    "you want",
    "want avoid",
    "avoid communication"
  ],
  "required_services": [
    "manual",
    "Function Item",
    "uProc"
  ],
  "triggers": [
    "Manual Trigger"
  ],
  "complexity": "simple",
  "workflow": {
    "id": "114",
    "name": "Verify phone numbers",
    "nodes": [
      {
        "name": "On clicking 'execute'",
        "type": "n8n-nodes-base.manualTrigger",
        "position": [
          440,
          510
        ],
        "parameters": {},
        "typeVersion": 1
      },
      {
        "name": "Create Phone Item",
        "type": "n8n-nodes-base.functionItem",
        "position": [
          640,
          510
        ],
        "parameters": {
          "functionCode": "item.phone = \"+1234567890\";\nreturn item;"
        },
        "typeVersion": 1
      },
      {
        "name": "Parse and Validate Phone",
        "type": "n8n-nodes-base.uproc",
        "position": [
          850,
          510
        ],
        "parameters": {
          "tool": "getPhoneParsed",
          "phone": "={{$node[\"Create Phone Item\"].json[\"phone\"]}}",
          "additionalOptions": {}
        },
        "credentials": {
          "uprocApi": {
            "id": "credential-id",
            "name": "uprocApi Credential"
          }
        },
        "typeVersion": 1
      },
      {
        "name": "Phone is Valid?",
        "type": "n8n-nodes-base.if",
        "position": [
          1050,
          510
        ],
        "parameters": {
          "conditions": {
            "string": [
              {
                "value1": "={{$node[\"Parse and Validate Phone\"].json[\"message\"][\"valid\"]+\"\"}}",
                "value2": "true"
              }
            ]
          }
        },
        "typeVersion": 1
      }
    ],
    "active": false,
    "settings": {},
    "connections": {
      "Create Phone Item": {
        "main": [
          [
            {
              "node": "Parse and Validate Phone",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "On clicking 'execute'": {
        "main": [
          [
            {
              "node": "Create Phone Item",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Parse and Validate Phone": {
        "main": [
          [
            {
              "node": "Phone is Valid?",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    }
  }
}
