          250,
          300
        ],
        "parameters": {},
        "typeVersion": 1
      },
      {
        "name": "IF",
        "type": "n8n-nodes-base.if",
        "position": [
          600,
          150
        ],
        "parameters": {
          "conditions": {
            "number": [
              {
                "value1": "={{$runIndex}}",
                "value2": 4
              }
            ]
          }
        },
        "typeVersion": 1
      },
      {
        "name": "NoOp",
        "type": "n8n-nodes-base.noOp",
        "position": [
          750,
          300
        ],
        "parameters": {},
        "typeVersion": 1
      },
      {
        "name": "Twitter",
        "type": "n8n-nodes-base.twitter",
        "position": [
          440,
          300
        ],
        "parameters": {
          "text": "Hello from n8n!",
          "additionalFields": {}
        },
        "credentials": {
          "twitterOAuth1Api": "Dummy Account"
        },
        "typeVersion": 1
      }
    ],
