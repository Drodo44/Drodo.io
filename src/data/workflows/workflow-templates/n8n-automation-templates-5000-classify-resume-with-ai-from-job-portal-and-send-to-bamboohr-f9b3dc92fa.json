        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          111200
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "classify-resume-with-ai-from-job-portal-and-send-to-bamboohr",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-job-portal",
        "name": "Fetch data from Job portal",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          111200
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/job-portal",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-classify-resume-with-ai",
        "name": "AI: Classify Resume With Ai",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          111200
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: classify resume with AI"
        }
      },
      {
        "id": "send-bamboohr",
        "name": "Send to BambooHR",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          111200
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/bamboohr",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-111200",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          111200
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
