{
  "id": "official-991",
  "source": {
    "type": "official",
    "url": "https://n8n.io/workflows/991",
    "template_id": 991
  },
  "name": "Add new contacts from Autopilot to Airtable",
  "description": "This workflow allows you to receive updates when a new contact is added in Autopilot and add them to a base in Airtable.",
  "category": "AI",
  "tags": [
    "CRM",
    "Autopilot",
    "Edit Fields (Set)",
    "Airtable",
    "Autopilot Trigger",
    "add",
    "contacts",
    "autopilot",
    "airtable",
    "workflow",
    "allows"
  ],
  "task_keywords": [
    "add new contacts from autopilot to airtable",
    "autopilot",
    "update autopilot",
    "edit fields (set)",
    "update edit fields (set)",
    "airtable",
    "update airtable",
    "autopilot trigger",
    "add contacts",
    "contacts autopilot",
    "autopilot airtable",
    "airtable workflow"
  ],
  "required_services": [
    "Autopilot",
    "Edit Fields (Set)",
    "Airtable"
  ],
  "triggers": [
    "Autopilot Trigger"
  ],
  "complexity": "simple",
  "workflow": {
    "nodes": [
      {
        "name": "Autopilot Trigger",
        "type": "n8n-nodes-base.autopilotTrigger",
        "position": [
          470,
          200
        ],
        "webhookId": "d7aa9691-49cb-4b01-8ecc-9a38fd708cf2",
        "parameters": {
          "event": "contactAdded"
        },
        "credentials": {
          "autopilotApi": "Autopilot API Credentials"
        },
        "typeVersion": 1
      },
      {
        "name": "Set",
        "type": "n8n-nodes-base.set",
        "position": [
          670,
          200
        ],
        "parameters": {
          "values": {
            "string": [
              {
                "name": "First Name",
                "value": "={{$json[\"contact\"][\"FirstName\"]}}"
              },
              {
                "name": "Last Name",
                "value": "={{$json[\"contact\"][\"LastName\"]}}"
              },
              {
                "name": "Email",
                "value": "={{$json[\"contact\"][\"Email\"]}}"
              }
            ]
          },
          "options": {},
          "keepOnlySet": true
        },
        "typeVersion": 1
      },
      {
        "name": "Airtable",
        "type": "n8n-nodes-base.airtable",
        "position": [
          870,
          200
        ],
        "parameters": {
          "table": "Table 1",
          "options": {},
          "operation": "append",
          "application": "appflT9EkWRGsSFM2"
        },
        "credentials": {
          "airtableApi": "Airtable Credentials n8n"
        },
        "typeVersion": 1
      }
    ],
    "connections": {
      "Set": {
        "main": [
          [
            {
              "node": "Airtable",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Autopilot Trigger": {
        "main": [
          [
            {
              "node": "Set",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    }
  }
}
