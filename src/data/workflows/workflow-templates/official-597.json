  ],
  "task_keywords": [
    "create a table in cratedb and insert data",
    "manual",
    "create manual",
    "cratedb",
    "create cratedb",
    "edit fields (set)",
    "create edit fields (set)",
    "manual trigger",
    "create table",
    "table cratedb",
