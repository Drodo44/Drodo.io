  "complexity": "simple",
  "workflow": {
    "name": "Generate invoice pdf from Xero invoice and send to Accounting DB",
    "nodes": [
      {
        "id": "trigger-xero-invoice",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          134900
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "generate-invoice-pdf-from-xero-invoice-and-send-to-accounting-db",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-xero-invoice",
        "name": "Fetch data from Xero invoice",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          134900
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/xero-invoice",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-accounting-db",
        "name": "Send to Accounting DB",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          134900
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/accounting-db",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-134900",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          134900
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Xero invoice",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Xero invoice": {
        "main": [
          {
            "node": "Send to Accounting DB",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Accounting DB": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
