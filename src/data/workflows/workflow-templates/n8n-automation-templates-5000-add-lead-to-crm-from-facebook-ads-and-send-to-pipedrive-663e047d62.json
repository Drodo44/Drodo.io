  "triggers": [
    "webhook"
  ],
  "complexity": "simple",
  "workflow": {
    "name": "Add lead to crm from Facebook Ads and send to Pipedrive",
    "nodes": [
      {
        "id": "trigger-facebook-ads",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          32300
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "add-lead-to-crm-from-facebook-ads-and-send-to-pipedrive",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-facebook-ads",
        "name": "Fetch data from Facebook Ads",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          32300
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/facebook-ads",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-pipedrive",
        "name": "Send to Pipedrive",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          32300
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/pipedrive",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-32300",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          32300
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Facebook Ads",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Facebook Ads": {
        "main": [
          {
            "node": "Send to Pipedrive",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Pipedrive": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {},
    "active": false
  }
