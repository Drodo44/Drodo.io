  },
  "name": "generate-customer-success-playbooks-from-crm-data",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: generate-customer-success-playbooks-from-crm-data",
  "category": "AI",
  "tags": [
    "n8n advance",
