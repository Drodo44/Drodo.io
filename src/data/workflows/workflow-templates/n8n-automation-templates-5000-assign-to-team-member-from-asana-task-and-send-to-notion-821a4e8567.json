  "workflow": {
    "name": "Assign to team member from Asana task and send to Notion",
    "nodes": [
      {
        "id": "trigger-asana-task",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          150400
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "assign-to-team-member-from-asana-task-and-send-to-notion",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-asana-task",
        "name": "Fetch data from Asana task",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          150400
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/asana-task",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-notion",
        "name": "Send to Notion",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          150400
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/notion",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-150400",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          150400
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from Asana task",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from Asana task": {
        "main": [
