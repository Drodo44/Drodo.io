  "name": "Store document from Vendor application and send to SharePoint",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Store document from Vendor application and send to SharePoint",
  "category": "Communication",
  "tags": [
    "n8n 2000 workflows",
