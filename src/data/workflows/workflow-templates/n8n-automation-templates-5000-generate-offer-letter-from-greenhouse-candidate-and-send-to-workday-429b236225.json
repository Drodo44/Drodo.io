  "workflow": {
    "name": "Generate offer letter from Greenhouse candidate and send to Workday",
    "nodes": [
      {
        "id": "trigger-greenhouse-candidate",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          110100
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "generate-offer-letter-from-greenhouse-candidate-and-send-to-workday",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-greenhouse-candidate",
        "name": "Fetch data from Greenhouse candidate",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          110100
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/greenhouse-candidate",
          "responseFormat": "json"
        }
      },
      {
        "id": "ai-generate-offer-letter",
        "name": "AI: Generate Offer Letter",
        "type": "n8n-nodes-base.openAIApi",
        "typeVersion": 1,
        "position": [
          0,
          110100
        ],
        "parameters": {
          "model": "gpt-4",
          "operation": "complete",
          "prompt": "Perform the following action on the incoming data: generate offer letter"
        }
      },
      {
        "id": "send-workday",
        "name": "Send to Workday",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          110100
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/workday",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-110100",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          110100
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
