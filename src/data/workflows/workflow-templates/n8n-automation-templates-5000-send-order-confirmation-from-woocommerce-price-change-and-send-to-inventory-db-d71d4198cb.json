  "workflow": {
    "name": "Send order confirmation from WooCommerce price change and send to Inventory DB",
    "nodes": [
      {
        "id": "trigger-woocommerce-price-change",
        "name": "Incoming Trigger",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 1,
        "position": [
          -600,
          177700
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "send-order-confirmation-from-woocommerce-price-change-and-send-to-inventory-db",
          "responseCode": 200,
          "responseMode": "onReceived"
        }
      },
      {
        "id": "fetch-woocommerce-price-change",
        "name": "Fetch data from WooCommerce price change",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          -300,
          177700
        ],
        "parameters": {
          "method": "GET",
          "url": "https://api.example.com/woocommerce-price-change",
          "responseFormat": "json"
        }
      },
      {
        "id": "send-inventory-db",
        "name": "Send to Inventory DB",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 1,
        "position": [
          300,
          177700
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.example.com/inventory-db",
          "responseFormat": "json",
          "options": {}
        }
      },
      {
        "id": "error-handler-600-177700",
        "name": "Send Error to Slack",
        "type": "n8n-nodes-base.slack",
        "typeVersion": 1,
        "position": [
          600,
          177700
        ],
        "parameters": {
          "resource": "message",
          "operation": "post",
          "channel": "#automation-alerts",
          "text": "={{ $json.get('error_message', 'An error occurred') }}"
        }
      }
    ],
    "connections": {
      "Incoming Trigger": {
        "main": [
          [
            {
              "node": "Fetch data from WooCommerce price change",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Fetch data from WooCommerce price change": {
        "main": [
          {
            "node": "Send to Inventory DB",
            "type": "main",
            "index": 0
          }
        ]
      },
      "Send to Inventory DB": {
        "main": [
          [
            {
              "node": "Send Error to Slack",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
