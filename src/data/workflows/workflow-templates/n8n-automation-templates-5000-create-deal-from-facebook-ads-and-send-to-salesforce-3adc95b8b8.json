  },
  "name": "Create deal from Facebook Ads and send to Salesforce",
  "description": "n8n workflow template from ritik-prog/n8n-automation-templates-5000: Create deal from Facebook Ads and send to Salesforce",
  "category": "Sales",
  "tags": [
    "n8n 2000 workflows",
    "slack",
