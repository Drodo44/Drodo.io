{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:scope-localdata-recursive",
    "fs:allow-localdata-read-recursive",
    "fs:allow-localdata-write-recursive",
    "notification:default",
    "process:default",
    "shell:default",
    "opener:default",
    "updater:default"
  ]
}
