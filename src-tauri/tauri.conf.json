{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Drodo",
  "version": "1.2.55",
  "identifier": "io.drodo.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Drodo",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis",
      "msi",
      "dmg",
      "appimage"
    ],
    "publisher": "Drodo",
    "copyright": "Copyright © 2024 Drodo",
    "resources": [
      "../scripts/install-dependencies.ps1",
      "../scripts/install-dependencies.sh"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerHooks": "./nsis/installer.nsh",
        "languages": [
          "English"
        ],
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "drodo"
        ]
      }
    },
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJBNDg0NzZEMjZFOTNDRUUKUldUdVBPa21iVWRJS2xkWmFNS0diTDlGYTlJaVNqdXpjczkxRTAvSWgySitXT0JNM1J2b2NFRVIK",
      "endpoints": [
        "https://github.com/Drodo44/Drodo.io/releases/latest/download/latest.json"
      ]
    }
  }
}
